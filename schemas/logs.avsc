{
  "type": "record",
  "namespace": "com.confluent.crewai",
  "name": "CrewaiLog",
  "doc": "One LLM prompt (input) or completion (output), emitted by any agent for UI feedback and observability.",
  "fields": [
    { "name": "agent_name", "type": "string" },
    { "name": "report_id", "type": "string" },
    { "name": "timestamp", "type": "long", "doc": "Epoch milliseconds." },
    { "name": "type", "type": { "type": "enum", "name": "LogType", "symbols": ["input", "output"] }, "doc": "Direction of the LLM exchange." },
    { "name": "data", "type": "string", "doc": "The prompt text (input) or response text (output)." },
    { "name": "tokens", "type": ["null", "int"], "default": null, "doc": "Token count from provider usage; null for input (pre-call)." },
    { "name": "model", "type": "string", "doc": "LLM model id used." }
  ]
}
