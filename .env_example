# Docker Compose
export CP_VERSION="8.2.0"
export CP_PROMETHEUS="2.5.0"
export CP_ALERTMANAGER="2.5.0"
export CP_C3="2.5.0"
export CP_DATAGEN="0.6.4-7.6.0"
export CP_ELASTIC_SINK_VERSION=15.1.2
export CP_FLINK="1.19.1-scala_2.12-java17"
export KIBANA_VERSION=8.15.3
export ELASTIC_VERSION=8.15.3

export LLM_PROVIDER="OLLAMA"  # or set "AWS" for AWS Bedrock models

# OLLAMA Config (if LLM_PROVIDER="OLLAMA")
# Default reaches the *host* Ollama from inside Docker Desktop (Mac/Windows),
# reusing host-pulled, GPU-accelerated models. On Linux, add
# `extra_hosts: ["host.docker.internal:host-gateway"]` to the agent services
# (or point this at a containerized/remote Ollama).
export OLLAMA_BASE_URL="http://host.docker.internal:11434"
export OLLAMA_MODEL_RESEARCH="gemma4:e4b"
export OLLAMA_MODEL_VALIDATOR="gemma4:e4b"
export OLLAMA_MODEL_REPORT="gemma4:e4b"

# AWS Config (if LLM_PROVIDER="AWS")
export AWS_REGION_NAME="eu-west-1"
export AWS_ACCESS_KEY_ID="<your-aws-access-key-id>"
export AWS_SECRET_ACCESS_KEY="<your-aws-secret-access-key>"
export BEDROCK_MODEL_RESEARCH="bedrock/eu.anthropic.claude-sonnet-4-6"
export BEDROCK_MODEL_VALIDATOR="bedrock/eu.anthropic.claude-sonnet-4-6"
export BEDROCK_MODEL_REPORT="bedrock/eu.anthropic.claude-opus-4-8"

# -----------------------------------------------------------------------------
# Application configuration (see common/settings.py)
# -----------------------------------------------------------------------------
# All of these have working defaults in common/settings.py (the docker-compose
# service names). Uncomment to override.
#
# The BEDROCK_MODEL_* vars are already wired into docker-compose.yml, so setting
# them here takes effect immediately. The infrastructure URLs and
# MAX_RESEARCH_ITERATIONS are read inside the containers from settings.py
# defaults; to override those, also add the var to the relevant service's
# `environment:` block in docker-compose.yml.

# --- Kafka / Schema Registry (container service-name defaults) ---
# KAFKA_BOOTSTRAP_SERVERS=broker:29092
# SCHEMA_REGISTRY_URL=http://schema-registry:8081

# --- Web search / MCP (container service-name defaults) ---
# SEARXNG_URL=http://searxng:8080
# MCP_SERVER_URL=http://mcp-server:8000/mcp

# --- Bedrock model ids (override to match models enabled in your eu-west-1) ---
# Reached via EU cross-region inference profiles (the `eu.` prefix).
# export BEDROCK_MODEL_RESEARCH="bedrock/eu.anthropic.claude-sonnet-4-6"
# export BEDROCK_MODEL_VALIDATOR="bedrock/eu.anthropic.claude-sonnet-4-6"
# export BEDROCK_MODEL_REPORT="bedrock/eu.anthropic.claude-opus-4-8"

# --- Choreography ---
# Validator forces a report once research has looped this many times.
# MAX_RESEARCH_ITERATIONS=5
